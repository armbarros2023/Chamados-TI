[Unit]
Description=Backup do banco de dados do Chamados TI
After=postgresql.service

[Service]
Type=oneshot
User=chamados-ti
Group=chamados-ti
WorkingDirectory=/opt/chamados-ti/current/backend
EnvironmentFile=/etc/chamados-ti-prod.env
ExecStart=/usr/bin/node scripts/backup-db.mjs
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/var/backups/chamados-ti-prod
