# Instalar em /etc/chamados-ti-prod.env com permissao 0640 e grupo chamados-ti.
# Nunca versionar o arquivo preenchido.
NODE_ENV=production
HOST=127.0.0.1
PORT=3103
TRUST_PROXY=true

# Persistente entre releases; inclui avatares e anexos privados.
DATA_DIR=/var/lib/chamados-ti
BACKUP_DIR=/var/backups/chamados-ti-prod

# Preencher somente na VPS com credenciais exclusivas de producao.
DATABASE_URL=postgresql://chamados_ti_app:SUBSTITUA_A_SENHA@127.0.0.1:5432/chamados_ti_prod
JWT_SECRET=SUBSTITUA_POR_UM_SEGREDO_ALEATORIO_DE_PELO_MENOS_32_CARACTERES
CLIENT_URLS=https://chamados.arbtechinfo.com
DB_SSL_ENABLED=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Preencher apenas se as notificacoes por e-mail forem ativadas.
BREVO_API_USER=
BREVO_API_PASS=
VALIDATED_SENDER_EMAIL=
SMTP_HOST=
SMTP_PORT=587
